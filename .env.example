# Variáveis de Ambiente para Produção
# Copie este arquivo para .env e preencha os valores

# ===========================================
# Banco de Dados (PostgreSQL)
# ===========================================
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ===========================================
# RabbitMQ
# ===========================================
RABBITMQ_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ===========================================
# Segurança
# ===========================================
# Pepper para hashing de senhas (use um valor único e seguro)
PASSWORD_PEPPER=CHANGE_ME_SECURE_PEPPER_MIN_32_CHARS

# ===========================================
# API
# ===========================================
VERSION=latest

# ===========================================
# JWT
# ===========================================
JWT_SECRET=CHANGE_ME_SECURE_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRATION=86400000

# ===========================================
# Redis
# ===========================================
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# ===========================================
# SMTP (para notificações)
# ===========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
